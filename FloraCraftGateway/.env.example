# FloraCraft Gateway – environment configuration
# Copy this file to .env and fill in your values.

# Supabase project URL  (e.g. https://abcxyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon / service-role key
SUPABASE_KEY=your-anon-or-service-key

# UUID of your device row in public.devices
DEVICE_ID=00000000-0000-0000-0000-000000000000

# Serial port the HC-05 / ZS-040 Bluetooth module appears on
# Windows example: COM3
# Linux example:   /dev/rfcomm0  or  /dev/ttyUSB0
SERIAL_PORT=COM3

# Serial baud rate (must match the Arduino sketch – default 9600)
BAUD_RATE=9600

# How often (in ms) to poll Supabase for new commands (default 3000)
POLL_INTERVAL_MS=3000
